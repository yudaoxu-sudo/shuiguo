# 登录信息和钉钉密钥只放本地 .env，不提交 git。
ZHIMADI_URL=https://aems.zhimadi.cn/index.php?s=/Index/index.html
ZHIMADI_USERNAME=
ZHIMADI_PASSWORD=

LEMENG_URL=https://sharec.lemengcloud.com/pos/home
LEMENG_USERNAME=
LEMENG_PASSWORD=

# 抖音开放平台生活服务商家自研应用。只放 .env，不提交 git。
DOUYIN_ENABLED=false
# 月报默认读取抖音来客后台现成的本月/门店汇总；api 只用于逐笔财务对账。
DOUYIN_SOURCE=browser
DOUYIN_FINANCE_URL=https://life.douyin.com/p/finance/v2/home
DOUYIN_PHONE=
DOUYIN_PASSWORD=
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_ACCOUNT_ID=
DOUYIN_PYTHON=
DOUYIN_TIMEOUT_SECONDS=30
DOUYIN_RETRY_ATTEMPTS=4
DOUYIN_PROCESS_TIMEOUT_MS=900000
DOUYIN_SETTLEMENT_CACHE_DIR=output/douyin-settlement-daily
DOUYIN_CURRENT_DAY_CACHE_SECONDS=600
DOUYIN_REQUEST_INTERVAL_SECONDS=0.1
DOUYIN_RATE_LIMIT_COOLDOWN_SECONDS=3600
DOUYIN_SETTLEMENT_DAYS=5
LEMENG_FEE_RATE=0.003

DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ALERT_MOBILES=
DINGTALK_ALERT_ALL=false

# 可选：用于自动识别芝麻地图形验证码。留空时会发验证码图片到钉钉让人回复。
OPENAI_API_KEY=
OPENAI_CAPTCHA_MODEL=gpt-4o-mini

# 可选：本地 ddddocr 先识别芝麻地图形验证码，识别失败再走 OpenAI/钉钉人工回复。
DDDDOCR_ENABLED=true
DDDDOCR_PYTHON=
DDDDOCR_TIMEOUT_MS=15000
ZHIMADI_CAPTCHA_AUTO_ATTEMPTS=2

# 本地调试先用 false，看得见浏览器；服务器上改 true。
HEADLESS=false

# 本地/服务器排查时可设为 1，只输出报表，不推送钉钉。
NO_DINGTALK=0

# 单个平台读取失败时自动重试次数。
REPORT_STEP_ATTEMPTS=3
BROWSER_LOCK_WAIT_MS=600000
BROWSER_LOCK_STALE_MS=1800000
REPORT_ALERT_COOLDOWN_MS=3600000
REPORT_HEALTHCHECK_TIMEOUT_MS=600000

# Mac 本地可用系统 Chrome；服务器通常留空并运行 `pnpm exec playwright install chromium`。
CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# 保存登录态。第一次手动登录后，后续定时任务复用这里的 Cookie。
USER_DATA_DIR=output/browser-profile
